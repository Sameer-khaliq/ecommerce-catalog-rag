eval/results/*.json
!eval/results/.gitkeep

# ---- Testing / coverage ----
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/

# ---- Ruff / linting cache ----
.ruff_cache/

# ---- Locust load test output ----
load_test/reports/
*.html

