# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- uv ----
# uv.lock SHOULD be committed for reproducible builds — do not ignore it

# ---- Environment / secrets ----
.env
.env.local
.env.*.local
*.pem
*.key

